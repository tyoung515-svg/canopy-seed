# Canopy Seed — Environment Configuration
# Copy this file to .env. API keys are NOT stored here.
#
# ── Key Management ───────────────────────────────────────────────────────────
#
# Canopy Seed uses a built-in encrypted vault for all API keys.
# On first launch, the vault setup screen will appear — enter your
# keys there. They are encrypted with AES-256-GCM and stored in
# memory/vault.enc. Your keys never touch this file.
#
# VAULT_MODE=true  → keys come from the vault (default, recommended)
# VAULT_MODE=false → keys read from env vars below (advanced / CI only)
#
VAULT_MODE=true

# ── Advanced: env-var key override (only used when VAULT_MODE=false) ─────────
# Leave these blank unless you have a specific reason to bypass the vault.
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
# Port for the API server (UI connects here)
DASHBOARD_API_PORT=7822

# ── Local AI (optional — only if running LM Studio or Ollama locally) ────────
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=your-local-model-name
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# AUTHORIZED_USER_IDS=

# ── Paths ─────────────────────────────────────────────────────────────────────
EXPORTS_PATH=exports

# ── Debug ─────────────────────────────────────────────────────────────────────
# DEBUG_MODE=false
