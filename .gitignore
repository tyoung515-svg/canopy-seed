# ── Canopy Seed .gitignore ──────────────────────────────────────
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment / secrets
.env
vault.enc
memory/vault.enc

# Generated output — never commit user builds
exports/*/
!exports/.gitkeep
outputs/*/
!outputs/.gitkeep

# Logs
logs/*.log
logs/*.txt
!logs/.gitkeep

# Databases (regenerated on first run)
memory/*.db
memory/*.db-journal
memory/sessions/*/
!memory/sessions/.gitkeep

# Test artifacts
.pytest_cache/
test_err.txt
test_output.txt
test-results/
*.pytest_cache

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Archives / builds
*.zip
*.tar.gz
*.whl

# Session/agent scratch files
SESSION_*.md
CLAUDE.md
CONTEXT.md
ziqLRA5j
